generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BabySex {
  GIRL
  BOY

  @@map("baby_sex")
}

enum BabyUserRole {
  FATHER
  MOTHER
  CAREGIVER

  @@map("baby_user_role")
}

enum RoutineMealType {
  breastfeed
  breastMilk
  formula
  solid

  @@map("routine_meal_type")
}

enum BreastSide {
  left
  right

  @@map("breast_side")
}

enum RoutineDiaperType {
  wet
  dirty
  both
  dry

  @@map("routine_diaper_type")
}

enum RoutineDiaperColor {
  green
  brown
  yellow
  black

  @@map("routine_diaper_color")
}

enum SleepType {
  nap
  nighttime

  @@map("sleep_type")
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String    @unique
  displayName        String?   @map("display_name")
  authProvider       String    @map("auth_provider")
  authProviderUserId String    @map("auth_provider_user_id")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz(6)

  babyAccesses BabyUser[]
  createdBabies Baby[]     @relation("BabyCreatedBy")
  createdMealEvents RoutineMealEvent[] @relation("RoutineMealCreatedBy")
  createdDiaperEvents RoutineDiaperEvent[] @relation("RoutineDiaperCreatedBy")
  createdSleepSessions SleepSession[] @relation("SleepSessionCreatedBy")

  @@unique([authProvider, authProviderUserId])
  @@map("users")
}

model Baby {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  birthdate       DateTime  @db.Date
  sex             BabySex   @default(BOY)
  timezone        String
  avatarObjectKey String?   @map("avatar_object_key")
  createdById     String    @map("created_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  createdBy User       @relation("BabyCreatedBy", fields: [createdById], references: [id])
  users     BabyUser[]
  mealEvents RoutineMealEvent[]
  diaperEvents RoutineDiaperEvent[]
  sleepSessions SleepSession[]
  routineSummaries DailyRoutineSummary[]
  growthRecords BabyGrowth[]

  @@index([createdById])
  @@map("babies")
}

model BabyUser {
  id        String       @id @default(uuid()) @db.Uuid
  babyId    String       @map("baby_id") @db.Uuid
  userId    String       @map("user_id") @db.Uuid
  role      BabyUserRole
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?    @map("deleted_at") @db.Timestamptz(6)

  baby Baby @relation(fields: [babyId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([babyId, userId])
  @@index([userId])
  @@map("baby_users")
}

model RoutineMealEvent {
  id              String          @id @default(uuid()) @db.Uuid
  babyId          String          @map("baby_id") @db.Uuid
  loggedAt        DateTime        @map("logged_at") @db.Timestamptz(6)
  mealType        RoutineMealType @map("meal_type")
  amountMl        Int?            @map("amount_ml")
  durationMinutes Int?            @map("duration_minutes")
  amountBowl      Decimal?        @map("amount_bowl") @db.Decimal(4, 2)
  amountGrams     Int?            @map("amount_grams")
  breastSide      BreastSide?     @map("breast_side")  
  notes           String?
  clientMutationId String?         @unique @map("client_mutation_id")
  createdById     String          @map("created_by") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  baby      Baby @relation(fields: [babyId], references: [id], onDelete: Cascade)
  createdBy User @relation("RoutineMealCreatedBy", fields: [createdById], references: [id])

  @@index([babyId, loggedAt])
  @@index([createdById])
  @@map("routine_meal_events")
}

model RoutineDiaperEvent {
  id          String              @id @default(uuid()) @db.Uuid
  babyId      String              @map("baby_id") @db.Uuid
  loggedAt    DateTime            @map("logged_at") @db.Timestamptz(6)
  diaperType  RoutineDiaperType   @map("diaper_type")
  color       RoutineDiaperColor?
  notes       String?
  clientMutationId String?         @unique @map("client_mutation_id")
  createdById String              @map("created_by") @db.Uuid
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  baby      Baby @relation(fields: [babyId], references: [id], onDelete: Cascade)
  createdBy User @relation("RoutineDiaperCreatedBy", fields: [createdById], references: [id])

  @@index([babyId, loggedAt])
  @@index([createdById])
  @@map("routine_diaper_events")
}

model SleepSession {
  id          String    @id @default(uuid()) @db.Uuid
  babyId      String    @map("baby_id") @db.Uuid
  sleepType   SleepType @map("sleep_type")
  startTime   DateTime  @map("start_time") @db.Timestamptz(6)
  endTime     DateTime? @map("end_time") @db.Timestamptz(6)
  notes       String?
  clientMutationId String? @unique @map("client_mutation_id")
  createdById String    @map("created_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  baby      Baby @relation(fields: [babyId], references: [id], onDelete: Cascade)
  createdBy User @relation("SleepSessionCreatedBy", fields: [createdById], references: [id])

  @@index([babyId, startTime])
  @@index([babyId, endTime])
  @@index([createdById])
  @@map("sleep_sessions")
}

model DailyRoutineSummary {
  id                String   @id @default(uuid()) @db.Uuid
  babyId            String   @map("baby_id") @db.Uuid
  summaryDate       DateTime @map("summary_date") @db.Date
  mealSummaryJson   Json     @map("meal_summary_json")
  diaperSummaryJson Json     @map("diaper_summary_json")
  sleepSummaryJson  Json     @map("sleep_summary_json")
  computedAt        DateTime @map("computed_at") @db.Timestamptz(6)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  baby Baby @relation(fields: [babyId], references: [id], onDelete: Cascade)

  @@unique([babyId, summaryDate])
  @@index([babyId, summaryDate])
  @@map("daily_routine_summaries")
}

model BabyGrowth {
  id                  String   @id @default(uuid()) @db.Uuid
  babyId              String   @map("baby_id") @db.Uuid
  heightMm            Int? @map("height_mm")
  weightGrams         Int? @map("weight_grams")
  headCircumferenceMm Int? @map("head_circumference_mm")
  notes               String?
  measuredDate        DateTime @map("measured_date") @db.Date
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  baby Baby @relation(fields: [babyId], references: [id], onDelete: Cascade)
  
  @@unique([babyId, measuredDate])
  @@map("baby_growth")
}
